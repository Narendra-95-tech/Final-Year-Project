<% layout("/layouts/boilerplate") -%>

    <!-- Toast Container -->
    <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

    <div style="background: #0f0e1a; min-height: 100vh; padding-bottom: 5rem; font-family: 'Inter', sans-serif;">

        <!-- ─── Header ──────────────────────────────────────────────── -->
        <div class="td-header">
            <div class="td-header-glow"></div>
            <div class="container td-header-inner">

                <!-- Breadcrumb -->
                <div class="td-breadcrumb">
                    <a href="/trip-planner">AI Planner</a>
                    <span class="td-bc-sep">›</span>
                    <a href="/api/trip/my-trips">My Trips</a>
                    <span class="td-bc-sep">›</span>
                    <span>
                        <%= trip.destination %>
                    </span>
                </div>

                <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mt-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="td-emoji-badge">
                            <%= trip.emoji || '✈️' %>
                        </div>
                        <div>
                            <h1 class="td-title">
                                <%= trip.title || trip.destination %>
                            </h1>
                            <div class="td-meta-row">
                                <span>📍 <%= trip.destination %></span>
                                <span>📅 <%= trip.duration %> day<%= trip.duration> 1 ? 's' : '' %></span>
                                <span>👥 <%= trip.travelers || 2 %> traveler<%= (trip.travelers||2)> 1 ? 's' : ''
                                            %></span>
                                <span>💰 ₹<%= (trip.budget || 0).toLocaleString('en-IN') %></span>
                            </div>
                            <% if (trip.preferences) { %>
                                <div class="td-prefs-row mt-2">
                                    <% trip.preferences.split(',').forEach(p=> { %>
                                        <span class="td-pref-chip">
                                            <%= p.trim() %>
                                        </span>
                                        <% }) %>
                                </div>
                                <% } %>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="td-actions">
                        <button class="td-btn" id="copyBtn">📋 Copy</button>
                        <button class="td-btn" id="printBtn">🖨️ Print</button>
                        <button class="td-btn" id="downloadPdfBtn">📄 Download PDF</button>
                        <button class="td-btn td-btn-danger" id="deleteBtn" data-id="<%= trip._id %>">🗑️
                            Delete</button>
                        <a href="/trip-planner" class="td-btn td-btn-primary">✨ New Trip</a>
                    </div>
                </div>

                <div class="td-saved-at">
                    Saved on <%= new Date(trip.createdAt).toLocaleDateString('en-IN', { weekday: 'long' , day: 'numeric'
                        , month: 'long' , year: 'numeric' }) %>
                </div>
            </div>
        </div>

        <div class="container mt-4">
            <div class="row g-4">

                <!-- ─── Left: Full Itinerary ─────────────────────────── -->
                <div class="col-lg-8">
                    <div class="td-content-card">
                        <div class="td-content-header">
                            <span class="td-content-label">📋 Full Itinerary</span>
                            <span class="td-word-count" id="wordCount">Loading…</span>
                        </div>
                        <div class="td-content-body" id="itineraryBody">
                            <%- trip.content %>
                        </div>
                    </div>
                </div>

                <!-- ─── Right: Sidebar ───────────────────────────────── -->
                <div class="col-lg-4">
                    <!-- Quick Summary -->
                    <div class="td-sidebar-card mb-3">
                        <h5 class="td-sidebar-title">📊 Trip Summary</h5>
                        <div class="td-summary-rows">
                            <div class="td-summary-row">
                                <span>Destination</span>
                                <strong>
                                    <%= trip.destination %>
                                </strong>
                            </div>
                            <div class="td-summary-row">
                                <span>Duration</span>
                                <strong>
                                    <%= trip.duration %> day<%= trip.duration>1?'s':'' %>
                                </strong>
                            </div>
                            <div class="td-summary-row">
                                <span>Travelers</span>
                                <strong>
                                    <%= trip.travelers || 2 %>
                                </strong>
                            </div>
                            <div class="td-summary-row">
                                <span>Budget</span>
                                <strong>₹<%= (trip.budget||0).toLocaleString('en-IN') %></strong>
                            </div>
                            <% if (trip.estimatedCost) { %>
                                <div class="td-summary-row">
                                    <span>Est. Cost</span>
                                    <strong class="text-success">
                                        <%= trip.estimatedCost %>
                                    </strong>
                                </div>
                                <% } %>
                                    <div class="td-summary-row">
                                        <span>Saved On</span>
                                        <strong>
                                            <%= new Date(trip.createdAt).toLocaleDateString('en-IN', { day:'numeric',
                                                month:'short', year:'numeric' }) %>
                                        </strong>
                                    </div>
                        </div>
                    </div>

                    <!-- Weather Forecast -->
                    <div class="td-sidebar-card mb-3" id="weatherWidget" style="display: none;">
                        <h5 class="td-sidebar-title">🌥️ Local Weather</h5>
                        <div class="d-flex align-items-center gap-3">
                            <img id="weatherIcon" src="" alt="Weather" style="width: 50px; height: 50px;">
                            <div>
                                <div id="weatherTemp" class="h4 mb-0 text-white fw-bold">--°C</div>
                                <div id="weatherDesc" class="small text-capitalize text-muted">Loading...</div>
                            </div>
                        </div>
                        <div class="td-summary-rows mt-3">
                            <div class="td-summary-row">
                                <span>Humidity</span>
                                <strong id="weatherHumidity">--%</strong>
                            </div>
                            <div class="td-summary-row">
                                <span>Wind</span>
                                <strong id="weatherWind">-- km/h</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Plan Another -->
                    <div class="td-sidebar-card td-plan-again">
                        <div class="td-plan-again-icon">🤖</div>
                        <h6>Want a different plan?</h6>
                        <p>Our AI can generate alternate itineraries for the same destination.</p>
                        <a href="/trip-planner?dest=<%= encodeURIComponent(trip.destination) %>&dur=<%= trip.duration %>&bgt=<%= trip.budget %>"
                            class="td-btn td-btn-primary w-100 d-block text-center">
                            ✨ Regenerate Plan
                        </a>
                    </div>

                    <!-- Share -->
                    <div class="td-sidebar-card mb-3">
                        <h5 class="td-sidebar-title">🗺️ Itinerary Map</h5>
                        <div id="tripMap" class="td-map-container mb-3"
                            style="height: 250px; border-radius: 12px; overflow: hidden; border: 1px solid var(--td-border);">
                        </div>
                        <div id="mapStatus" class="small text-center text-muted">Scanning locations...</div>
                    </div>

                    <!-- Quick Summary -->
                    <div class="td-sidebar-card mt-3">
                        <h5 class="td-sidebar-title">📤 Share Itinerary</h5>
                        <div class="d-flex flex-column gap-2">
                            <button class="td-share-btn" id="shareWhatsApp">
                                <span>💬</span> Share on WhatsApp
                            </button>
                            <button class="td-share-btn" id="shareCopyLink">
                                <span>🔗</span> Copy Link
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <!-- Marked.js & html2pdf.js -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        (function () {
            // ─── Render markdown content ───────────────────────────────────────
            const body = document.getElementById('itineraryBody');
            const rawText = body.textContent;
            body.innerHTML = marked.parse(rawText);

            // Style tables
            body.querySelectorAll('table').forEach(t => t.classList.add('td-table'));

            // Word count
            const words = rawText.trim().split(/\s+/).length;
            const readMins = Math.ceil(words / 200);
            document.getElementById('wordCount').textContent = `~${readMins} min read`;

            // ─── Mapbox Itinerary Map ──────────────────────────────────────────
            let map;
            const mapToken = '<%= process.env.MAPBOX_TOKEN %>';
            const locations = [];
            const markers = [];

            // Extract locations using regex: 📍 *Location:* [Place name]
            const locationRegex = /📍\s*\*Location:\*\s*([^\|\n\r]+)/g;
            let match;
            while ((match = locationRegex.exec(rawText)) !== null) {
                const place = match[1].trim();
                if (!locations.includes(place)) locations.push(place);
            }

            if (locations.length > 0 && mapToken) {
                mapboxgl.accessToken = mapToken;
                map = new mapboxgl.Map({
                    container: 'tripMap',
                    style: 'mapbox://styles/mapbox/navigation-night-v1',
                    center: [78.9629, 20.5937], // Default India center
                    zoom: 3
                });

                map.on('load', async () => {
                    const status = document.getElementById('mapStatus');
                    const coords = [];

                    for (const place of locations) {
                        try {
                            const response = await fetch(`https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(place + ', ' + '<%= trip.destination %>')}.json?access_token=${mapToken}&limit=1`);
                            const data = await response.json();
                            if (data.features && data.features.length > 0) {
                                const [lng, lat] = data.features[0].center;
                                coords.push([lng, lat]);

                                // Add marker
                                const el = document.createElement('div');
                                el.className = 'td-map-marker';
                                el.innerHTML = `<span>${markers.length + 1}</span>`;

                                const marker = new mapboxgl.Marker(el)
                                    .setLngLat([lng, lat])
                                    .setPopup(new mapboxgl.Popup({ offset: 25 }).setHTML(`<strong>${place}</strong>`))
                                    .addTo(map);

                                markers.push(marker);
                            }
                        } catch (e) { console.error('Geocoding error:', e); }
                    }

                    if (coords.length > 1) {
                        // Draw Route Line
                        map.addSource('route', {
                            'type': 'geojson',
                            'data': {
                                'type': 'Feature',
                                'properties': {},
                                'geometry': {
                                    'type': 'LineString',
                                    'coordinates': coords
                                }
                            }
                        });

                        map.addLayer({
                            'id': 'route',
                            'type': 'line',
                            'source': 'route',
                            'layout': { 'line-join': 'round', 'line-cap': 'round' },
                            'paint': {
                                'line-color': '#6366f1',
                                'line-width': 4,
                                'line-opacity': 0.6,
                                'line-dasharray': [1, 1]
                            }
                        });

                        // Fit Bounds
                        const bounds = new mapboxgl.LngLatBounds();
                        coords.forEach(c => bounds.extend(c));
                        map.fitBounds(bounds, { padding: 40, animate: true });
                        status.textContent = `📍 ${coords.length} stops mapped`;
                    } else if (coords.length === 1) {
                        map.setCenter(coords[0]);
                        map.setZoom(12);
                        status.textContent = '📍 Destination marked';
                    } else {
                        status.textContent = '❌ Could not plot locations';
                    }
                });
            } else {
                document.getElementById('mapStatus').textContent = 'No specific locations found to map.';
            }

            // ─── Copy ──────────────────────────────────────────────────────────
            document.getElementById('copyBtn').addEventListener('click', async () => {
                try {
                    await navigator.clipboard.writeText(rawText);
                    showToast('Itinerary copied to clipboard! 📋', 'success');
                } catch {
                    showToast('Could not copy automatically. Please select and copy manually.', 'warning');
                }
            });

            // ─── Print ─────────────────────────────────────────────────────────
            document.getElementById('printBtn').addEventListener('click', () => {
                const win = window.open('', '_blank');
                win.document.write(`
            <html><head><title><%= trip.title || trip.destination %> — WanderLust</title>
            <style>
                body { font-family: Georgia, serif; max-width: 800px; margin: 40px auto; color: #222; }
                h1,h2,h3 { color: #4f46e5; }
                table { width:100%; border-collapse:collapse; margin:16px 0; }
                th { background:#4f46e5; color:#fff; padding:8px 12px; }
                td { border:1px solid #ddd; padding:8px 12px; }
            </style></head>
            <body>${body.innerHTML}</body></html>`);
                win.document.close();
                win.print();
            });

            // ─── Delete ────────────────────────────────────────────────────────
            document.getElementById('deleteBtn').addEventListener('click', async () => {
                if (!confirm('Permanently delete this trip? This cannot be undone.')) return;
                const btn = document.getElementById('deleteBtn');
                btn.textContent = '⏳ Deleting…';
                btn.disabled = true;

                try {
                    const res = await fetch(`/api/trip/my-trips/<%= trip._id %>`, {
                        method: 'DELETE',
                        headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
                        credentials: 'include'
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast('Trip deleted! Redirecting…', 'success');
                        setTimeout(() => window.location.href = '/api/trip/my-trips', 1500);
                    } else { throw new Error(data.message); }
                } catch (err) {
                    showToast(err.message || 'Failed to delete.', 'error');
                    btn.textContent = '🗑️ Delete';
                    btn.disabled = false;
                }
            });

            // ─── Share WhatsApp ────────────────────────────────────────────────
            document.getElementById('shareWhatsApp').addEventListener('click', () => {
                const msg = encodeURIComponent(`Check out my <%= trip.duration %>-day trip plan to <%= trip.destination %>! via WanderLust AI 🌍`);
                window.open(`https://wa.me/?text=${msg}%20${encodeURIComponent(window.location.href)}`, '_blank');
            });

            // ─── Share Copy Link ──────────────────────────────────────────────
            document.getElementById('shareCopyLink').addEventListener('click', async () => {
                try {
                    await navigator.clipboard.writeText(window.location.href);
                    showToast('Link copied! 🔗', 'success');
                } catch {
                    showToast('Could not copy link.', 'warning');
                }
            });

            // ─── Download PDF ──────────────────────────────────────────────────
            document.getElementById('downloadPdfBtn').addEventListener('click', () => {
                const element = document.getElementById('itineraryBody');
                const opt = {
                    margin: 1,
                    filename: '<%= trip.destination %>_Itinerary.pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true },
                    jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
                };

                // Add a header to the element for PDF
                const docHeader = document.createElement('div');
                docHeader.innerHTML = `
                    <div style="font-family: Arial, sans-serif; padding-bottom: 20px; border-bottom: 2px solid #6366f1; margin-bottom: 20px;">
                        <h1 style="color: #6366f1; margin: 0;">WanderLust AI Itinerary</h1>
                        <p style="color: #666; font-size: 14px; margin: 5px 0;">Destination: <%= trip.destination %> | Duration: <%= trip.duration %> Days</p>
                    </div>
                `;

                // Temporary container for PDF generation
                const printContainer = document.createElement('div');
                printContainer.style.padding = '40px';
                printContainer.style.background = '#fff';
                printContainer.style.color = '#333';
                printContainer.appendChild(docHeader);
                printContainer.appendChild(element.cloneNode(true));

                // Add some basic styles for the PDF content
                const styles = `
                    <style>
                        table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
                        th { background: #f3f4f6; padding: 10px; text-align: left; }
                        td { border-bottom: 1px solid #e5e7eb; padding: 8px 10px; }
                        h1, h2, h3 { color: #1f2937; }
                    </style>
                `;
                printContainer.insertAdjacentHTML('afterbegin', styles);

                html2pdf().set(opt).from(printContainer).save().then(() => {
                    showToast('PDF downloaded successfully! 📄', 'success');
                });
            });

            // ─── Weather Forecast ──────────────────────────────────────────────
            (async function fetchWeather() {
                try {
                    const res = await fetch(`/ai/assistant/weather?city=<%= encodeURIComponent(trip.destination) %>`);
                    const data = await res.json();
                    if (data && !data.error) {
                        document.getElementById('weatherWidget').style.display = 'block';
                        document.getElementById('weatherIcon').src = data.icon;
                        document.getElementById('weatherTemp').textContent = `${data.temperature}°C`;
                        document.getElementById('weatherDesc').textContent = data.description;
                        document.getElementById('weatherHumidity').textContent = `${data.humidity}%`;
                        document.getElementById('weatherWind').textContent = `${data.windSpeed} m/s`;
                    }
                } catch (err) {
                    console.error('Weather fetch error:', err);
                }
            })();

            // ─── Toast ─────────────────────────────────────────────────────────
            function showToast(msg, type = 'info') {
                const colors = { success: '#10b981', error: '#ef4444', warning: '#f59e0b', info: '#6366f1' };
                const icons = { success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
                const id = 'toast-' + Date.now();
                const el = document.createElement('div');
                el.id = id;
                el.className = 'tp-toast';
                el.style.cssText = `--toast-color:${colors[type] || colors.info}`;
                el.innerHTML = `<span>${icons[type]}</span><span style="flex:1;color:#e2e2f0;font-size:.85rem">${msg}</span><button onclick="document.getElementById('${id}').remove()" style="background:none;border:none;color:#9ca3af;cursor:pointer">×</button>`;
                document.getElementById('toast-container').appendChild(el);
                requestAnimationFrame(() => el.classList.add('show'));
                setTimeout(() => { el.classList.remove('show'); setTimeout(() => el.remove(), 400); }, 4000);
            }
        })();
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        :root {
            --td-primary: #6366f1;
            --td-primary2: #818cf8;
            --td-surface: #1a1830;
            --td-border: rgba(99, 102, 241, .2);
            --td-text: #e2e2f0;
            --td-muted: #9ca3af;
        }

        /* ─── Header ──────────────────────────────────────────── */
        .td-header {
            background: linear-gradient(135deg, #0f0e1a 0%, #1a1245 100%);
            padding: 2.5rem 0 2rem;
            border-bottom: 1px solid var(--td-border);
            position: relative;
            overflow: hidden;
        }

        .td-header-glow {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 50% 80% at 30% 50%, rgba(99, 102, 241, .18) 0%, transparent 70%);
        }

        .td-header-inner {
            position: relative;
            z-index: 1;
        }

        .td-breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .78rem;
            color: var(--td-muted);
            font-family: 'Inter', sans-serif;
        }

        .td-breadcrumb a {
            color: var(--td-primary2);
            text-decoration: none;
        }

        .td-breadcrumb a:hover {
            color: #fff;
        }

        .td-bc-sep {
            color: var(--td-muted);
        }

        .td-emoji-badge {
            width: 64px;
            height: 64px;
            font-size: 2.4rem;
            background: rgba(99, 102, 241, .15);
            border: 1px solid var(--td-border);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .td-title {
            font-size: 1.6rem;
            font-weight: 800;
            color: #fff;
            font-family: 'Inter', sans-serif;
            margin: 0 0 .4rem;
        }

        .td-meta-row {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            font-size: .82rem;
            color: var(--td-muted);
            font-family: 'Inter', sans-serif;
        }

        .td-prefs-row {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .td-pref-chip {
            background: rgba(99, 102, 241, .12);
            border: 1px solid rgba(99, 102, 241, .2);
            color: var(--td-primary2);
            border-radius: 100px;
            padding: 2px 10px;
            font-size: .72rem;
            font-weight: 500;
            font-family: 'Inter', sans-serif;
        }

        .td-saved-at {
            margin-top: .9rem;
            font-size: .75rem;
            color: var(--td-muted);
            font-family: 'Inter', sans-serif;
        }

        /* ─── Action Buttons ──────────────────────────────────── */
        .td-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .td-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 255, 255, .07);
            border: 1px solid rgba(255, 255, 255, .15);
            color: var(--td-text);
            border-radius: 10px;
            padding: 8px 14px;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            text-decoration: none;
            transition: all .2s;
        }

        .td-btn:hover {
            background: rgba(255, 255, 255, .12);
            color: #fff;
            transform: translateY(-1px);
        }

        .td-btn-primary {
            background: linear-gradient(135deg, var(--td-primary), #8b5cf6);
            border-color: transparent;
        }

        .td-btn-primary:hover {
            box-shadow: 0 8px 24px rgba(99, 102, 241, .4);
        }

        .td-btn-danger {
            border-color: rgba(239, 68, 68, .3);
            color: #ef4444;
        }

        .td-btn-danger:hover {
            background: rgba(239, 68, 68, .15);
        }

        /* ─── Content Card ────────────────────────────────────── */
        .td-content-card {
            background: var(--td-surface);
            border: 1px solid var(--td-border);
            border-radius: 20px;
            overflow: hidden;
        }

        .td-content-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(99, 102, 241, .08);
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--td-border);
        }

        .td-content-label {
            font-size: .82rem;
            font-weight: 700;
            color: var(--td-primary2);
            font-family: 'Inter', sans-serif;
        }

        .td-word-count {
            font-size: .75rem;
            color: var(--td-muted);
            font-family: 'Inter', sans-serif;
        }

        .td-content-body {
            padding: 2rem;
            color: var(--td-text);
            line-height: 1.85;
            font-family: 'Inter', sans-serif;
        }

        /* Markdown styles */
        .td-content-body h1 {
            font-size: 1.5rem;
            color: #fff;
            margin-top: 1.5rem;
        }

        .td-content-body h2 {
            font-size: 1.15rem;
            color: var(--td-primary2);
            border-bottom: 1px solid var(--td-border);
            padding-bottom: 6px;
            margin-top: 2rem;
        }

        .td-content-body h3 {
            font-size: 1rem;
            color: #c4b5fd;
            margin-top: 1.4rem;
        }

        .td-content-body p {
            color: var(--td-text);
            margin-bottom: .7rem;
        }

        .td-content-body em {
            color: var(--td-muted);
            font-style: normal;
            font-size: .9rem;
        }

        .td-content-body strong {
            color: #fff;
        }

        .td-content-body ul {
            padding-left: 1.4rem;
            margin-bottom: .8rem;
        }

        .td-content-body li {
            color: var(--td-text);
            margin-bottom: .35rem;
        }

        .td-content-body hr {
            border: none;
            border-top: 1px solid var(--td-border);
            margin: 1.5rem 0;
        }

        .td-content-body blockquote {
