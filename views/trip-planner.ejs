<% layout("/layouts/boilerplate") -%>

    <!-- Toast Container -->
    <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

    <div class="tp-hero">
        <div class="tp-hero-bg"></div>
        <div class="container tp-hero-content">
            <div class="tp-badge mb-3">
                <span class="tp-badge-icon">✨</span> AI-Powered Planning
            </div>
            <h1 class="tp-hero-title">Plan Your <span class="tp-gradient-text">Perfect Trip</span></h1>
            <p class="tp-hero-subtitle">Tell us where & our AI crafts a full personalized itinerary in seconds — stays,
                wheels & food included.</p>

            <!-- Quick Chips -->
            <div class="tp-chips" id="quickChips">
                <button class="tp-chip" data-dest="Goa" data-dur="3" data-bgt="15000"
                    data-pref="beach, party, seafood">🏖️ Goa Weekend</button>
                <button class="tp-chip" data-dest="Manali" data-dur="5" data-bgt="20000"
                    data-pref="snow, adventure, mountains">🏔️ Manali Adventure</button>
                <button class="tp-chip" data-dest="Rishikesh" data-dur="3" data-bgt="12000"
                    data-pref="yoga, rafting, camping">🛶 Rishikesh Vibes</button>
                <button class="tp-chip" data-dest="Kerala" data-dur="7" data-bgt="35000"
                    data-pref="houseboat, backwaters, family">🌴 Kerala Bliss</button>
                <button class="tp-chip" data-dest="Rajasthan" data-dur="6" data-bgt="25000"
                    data-pref="heritage, desert, culture">🏰 Rajasthan Royal</button>
                <button class="tp-chip" data-dest="Leh Ladakh" data-dur="7" data-bgt="40000"
                    data-pref="road trip, lakes, monasteries">🏕️ Leh-Ladakh</button>
            </div>
        </div>
    </div>

    <div class="container tp-main-container">
        <div class="row g-4">
            <!-- ─── Left: Form Panel ─────────────────────────────────────── -->
            <div class="col-lg-4">
                <div class="tp-form-card" id="formCard">
                    <div class="tp-form-header">
                        <div class="tp-ai-icon">🤖</div>
                        <div>
                            <h4 class="mb-0">WanderLust AI</h4>
                            <span class="tp-online-badge">● Online</span>
                        </div>
                    </div>

                    <form id="trip-planner-form" autocomplete="off">
                        <!-- Destination -->
                        <div class="tp-field-group">
                            <label class="tp-label">📍 Destination</label>
                            <div class="tp-input-wrap">
                                <input type="text" class="tp-input" id="destination" name="destination"
                                    placeholder="e.g., Manali, Himachal Pradesh" required>
                                <span class="tp-input-icon">🗺️</span>
                            </div>
                        </div>

                        <!-- Duration + Travelers -->
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="tp-field-group">
                                    <label class="tp-label">📆 Days</label>
                                    <input type="number" class="tp-input" id="duration" name="duration" min="1" max="30"
                                        value="3" required>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="tp-field-group">
                                    <label class="tp-label">👥 Travelers</label>
                                    <input type="number" class="tp-input" id="travelers" name="travelers" min="1"
                                        max="20" value="2" required>
                                </div>
                            </div>
                        </div>

                        <!-- Budget -->
                        <div class="tp-field-group">
                            <label class="tp-label">💰 Total Budget (₹)</label>
                            <div class="tp-input-wrap">
                                <input type="number" class="tp-input tp-input-budget" id="budget" name="budget"
                                    min="1000" value="15000" required>
                                <span class="tp-input-icon">₹</span>
                            </div>
                            <div class="tp-budget-slider-wrap mt-2">
                                <input type="range" class="tp-slider" id="budgetSlider" min="1000" max="200000"
                                    step="1000" value="15000">
                                <div class="tp-slider-labels">
                                    <span>₹1K</span><span>₹50K</span><span>₹2L</span>
                                </div>
                            </div>
                        </div>

                        <!-- Preferences -->
                        <div class="tp-field-group">
                            <label class="tp-label">🎯 Preferences (optional)</label>
                            <textarea class="tp-input tp-textarea" id="preferences" name="preferences"
                                placeholder="Family trip, adventure activities, luxury stays, vegetarian food…"></textarea>
                        </div>

                        <!-- Voice Input -->
                        <div class="tp-voice-row mb-3">
                            <button type="button" class="tp-voice-btn" id="voiceInputBtn"
                                title="Speak your preferences">
                                <span id="voiceIcon">🎙️</span> <span id="voiceText">Voice Input</span>
                            </button>
                        </div>

                        <button type="submit" class="tp-submit-btn" id="planTripBtn">
                            <span class="tp-submit-icon">✨</span>
                            <span id="planBtnText">Generate My Itinerary</span>
                        </button>
                    </form>

                    <!-- Follow-up Chat -->
                    <div class="tp-followup-wrap mt-3" id="followupWrap" style="display:none;">
                        <div class="tp-followup-label">💬 Ask follow-up questions</div>
                        <div class="tp-followup-row">
                            <input type="text" class="tp-followup-input" id="followupInput"
                                placeholder="e.g., Add a spa day on Day 2">
                            <button class="tp-followup-btn" id="followupBtn">➤</button>
                        </div>
                        <div class="tp-followup-suggestions mt-2" id="followupSuggestions">
                            <button class="tp-suggestion-chip">Make it budget-friendly</button>
                            <button class="tp-suggestion-chip">Add more adventure</button>
                            <button class="tp-suggestion-chip">Add vegetarian food options</button>
                            <button class="tp-suggestion-chip">Extend by 1 day</button>
                        </div>
                    </div>
                </div>

                <!-- My Trips shortcut (only if logged in) -->
                <% if (typeof currUser !=='undefined' && currUser) { %>
                    <a href="/api/trip/my-trips" class="tp-my-trips-card mt-3 d-block text-decoration-none">
                        <span class="tp-my-trips-icon">📚</span>
                        <div>
                            <div class="tp-my-trips-title">My Saved Trips</div>
                            <div class="tp-my-trips-sub">View & manage your itineraries</div>
                        </div>
                        <span class="tp-my-trips-arrow">→</span>
                    </a>
                    <% } %>
            </div>

            <!-- ─── Right: Output Panel ──────────────────────────────────── -->
            <div class="col-lg-8">
                <!-- Empty State -->
                <div class="tp-empty-state" id="emptyState">
                    <div class="tp-empty-animation">
                        <div class="tp-plane">✈️</div>
                        <div class="tp-cloud tp-cloud-1">☁️</div>
                        <div class="tp-cloud tp-cloud-2">☁️</div>
                    </div>
                    <h3>Ready to explore?</h3>
                    <p>Fill in your trip details on the left, or pick a quick destination above — our AI will craft a
                        full itinerary in seconds!</p>
                    <div class="tp-features-row">
                        <div class="tp-feature"><span>📋</span> Day-by-day plan</div>
                        <div class="tp-feature"><span>💰</span> Budget breakdown</div>
                        <div class="tp-feature"><span>🍽️</span> Restaurant picks</div>
                        <div class="tp-feature"><span>💡</span> Money-saving tips</div>
                        <div class="tp-feature"><span>🎒</span> Packing list</div>
                        <div class="tp-feature"><span>🆘</span> Emergency contacts</div>
                    </div>
                </div>

                <!-- Loading / Streaming State -->
                <div class="tp-streaming-card" id="streamingCard" style="display:none;">
                    <div class="tp-streaming-header">
                        <div class="tp-ai-typing">
                            <span class="tp-ai-dot"></span><span class="tp-ai-dot"></span><span
                                class="tp-ai-dot"></span>
                        </div>
                        <span class="tp-streaming-label">WanderLust AI is crafting your itinerary…</span>
                    </div>
                    <div class="tp-streaming-content" id="streamingContent"></div>
                </div>

                <!-- Result Card -->
                <div class="tp-result-card" id="resultCard" style="display:none;">
                    <!-- Result Toolbar -->
                    <div class="tp-result-toolbar">
                        <div class="tp-result-meta">
                            <span class="tp-result-emoji" id="resultEmoji">✈️</span>
                            <div>
                                <div class="tp-result-title" id="resultTitle">Your Trip Plan</div>
                                <div class="tp-result-sub" id="resultSub"></div>
                            </div>
                        </div>
                        <div class="tp-result-actions">
                            <button class="tp-action-btn tp-save-btn" id="saveTripBtn" title="Save Trip">
                                💾 Save
                            </button>
                            <button class="tp-action-btn" id="copyBtn" title="Copy to clipboard">
                                📋 Copy
                            </button>
                            <button class="tp-action-btn" id="printBtn" title="Print itinerary">
                                🖨️ Print
                            </button>
                            <button class="tp-action-btn tp-share-btn" id="shareBtn" title="Share">
                                📤 Share
                            </button>
                        </div>
                    </div>

                    <!-- Rendered Itinerary -->
                    <div class="tp-result-body" id="resultBody"></div>
                </div>
            </div>
        </div>
    </div>



    <!-- Marked.js for markdown rendering -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        /* ─────────────────────────────────────────────
           WanderLust AI Trip Planner — Client Script
           ───────────────────────────────────────────── */
        (function () {
            const form = document.getElementById('trip-planner-form');
            const emptyState = document.getElementById('emptyState');
            const streamCard = document.getElementById('streamingCard');
            const streamBody = document.getElementById('streamingContent');
            const resultCard = document.getElementById('resultCard');
            const resultBody = document.getElementById('resultBody');
            const resultTitle = document.getElementById('resultTitle');
            const resultSub = document.getElementById('resultSub');
            const resultEmoji = document.getElementById('resultEmoji');
            const followupWrap = document.getElementById('followupWrap');
            const planBtn = document.getElementById('planTripBtn');
            const planBtnText = document.getElementById('planBtnText');
            const saveTripBtn = document.getElementById('saveTripBtn');
            const copies = document.getElementById('copyBtn');
            const printBtn = document.getElementById('printBtn');
            const shareBtn = document.getElementById('shareBtn');
            const voiceBtn = document.getElementById('voiceInputBtn');
            const voiceIcon = document.getElementById('voiceIcon');
            const voiceText = document.getElementById('voiceText');
            const budgetInput = document.getElementById('budget');
            const budgetSlider = document.getElementById('budgetSlider');

            let currentConversationId = null;
            let currentPlanContent = '';
            let currentDest = '';

            // ─── Budget Slider Sync ───────────────────────────────────────────────
            budgetSlider.addEventListener('input', () => {
                budgetInput.value = budgetSlider.value;
            });
            budgetInput.addEventListener('input', () => {
                budgetSlider.value = budgetInput.value;
            });

            // ─── Quick Chips ─────────────────────────────────────────────────────
            document.getElementById('quickChips').addEventListener('click', (e) => {
                const chip = e.target.closest('.tp-chip');
                if (!chip) return;
                document.getElementById('destination').value = chip.dataset.dest;
                document.getElementById('duration').value = chip.dataset.dur;
                document.getElementById('budget').value = chip.dataset.bgt;
                budgetSlider.value = chip.dataset.bgt;
                document.getElementById('preferences').value = chip.dataset.pref;
                // Highlight active chip
                document.querySelectorAll('.tp-chip').forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
                // Auto-submit
                form.dispatchEvent(new Event('submit', { cancelable: true }));
            });

            // ─── Main Form Submit ─────────────────────────────────────────────────
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const dest = document.getElementById('destination').value.trim();
                const duration = document.getElementById('duration').value;
                const travelers = document.getElementById('travelers').value;
                const budget = document.getElementById('budget').value;
                const prefs = document.getElementById('preferences').value.trim();

                if (!dest) { showToast('Please enter a destination!', 'warning'); return; }

                currentDest = dest;
                currentConversationId = Date.now().toString();
                await runStreaming({ dest, duration, travelers, budget, prefs });
            });

            // ─── Follow-up ───────────────────────────────────────────────────────
            document.getElementById('followupBtn').addEventListener('click', sendFollowup);
            document.getElementById('followupInput').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') sendFollowup();
            });

            document.getElementById('followupSuggestions').addEventListener('click', (e) => {
                const chip = e.target.closest('.tp-suggestion-chip');
                if (!chip) return;
                document.getElementById('followupInput').value = chip.textContent;
                sendFollowup();
            });

            async function sendFollowup() {
                const msg = document.getElementById('followupInput').value.trim();
                if (!msg) return;
                document.getElementById('followupInput').value = '';
                await runStreaming({ message: msg });
            }

            // ─── Core Streaming Function ─────────────────────────────────────────
            async function runStreaming({ dest, duration, travelers, budget, prefs, message }) {
                // UI: show streaming state
                emptyState.style.display = 'none';
                resultCard.style.display = 'none';
                streamCard.style.display = 'block';
                streamBody.innerHTML = '';

                planBtn.disabled = true;
                planBtnText.textContent = 'Generating…';
                planBtn.classList.add('loading');

                let accumulated = '';

                try {
                    const payload = {
                        stream: true,
                        conversationId: currentConversationId
                    };

                    if (message) {
                        payload.message = message;
                    } else {
                        payload.destination = dest;
                        payload.duration = duration;
                        payload.travelers = travelers;
                        payload.budget = budget;
                        payload.preferences = prefs;
                    }

                    const res = await fetch('/api/trip/plan', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                        },
                        credentials: 'include',
                        body: JSON.stringify(payload)
                    });

                    if (!res.ok) {
                        const err = await res.json().catch(() => ({}));
                        throw new Error(err.message || `Server error (${res.status})`);
                    }

                    const reader = res.body.getReader();
                    const decoder = new TextDecoder();

                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;

                        const text = decoder.decode(value, { stream: true });
                        const lines = text.split('\n');

                        for (const line of lines) {
                            if (!line.startsWith('data: ')) continue;
                            try {
                                const parsed = JSON.parse(line.slice(6));
                                if (parsed.delta) {
                                    accumulated += parsed.delta;
                                    // Live render with marked
                                    streamBody.innerHTML = marked.parse(accumulated);
                                    streamCard.scrollTop = streamCard.scrollHeight;
                                }
                                if (parsed.done) {
                                    currentPlanContent = parsed.fullContent || accumulated;
                                    currentConversationId = parsed.conversationId;
                                }
                            } catch (_) { }
                        }
                    }

                    // Transition to result view
                    showResult(dest, duration, travelers, budget, currentPlanContent);
                    followupWrap.style.display = 'block';

                } catch (err) {
                    console.error('Streaming error:', err);
                    streamCard.style.display = 'none';
                    emptyState.style.display = 'block';
                    showToast(err.message || 'Failed to generate trip plan. Please try again.', 'error');
                } finally {
                    planBtn.disabled = false;
                    planBtnText.textContent = 'Generate My Itinerary';
                    planBtn.classList.remove('loading');
                }
            }

            // ─── Show Rendered Result ─────────────────────────────────────────────
            function showResult(dest, duration, travelers, budget, content) {
                streamCard.style.display = 'none';

                // Parse markdown
                resultBody.innerHTML = marked.parse(content || '');

                // Meta bar
                if (dest) {
                    resultTitle.textContent = `${duration || ''}${duration ? '-Day ' : ''}Trip to ${dest}`;
                    resultSub.textContent = `${travelers || 2} traveler${(travelers || 2) > 1 ? 's' : ''} · Budget ₹${Number(budget || 0).toLocaleString('en-IN')}`;
                    resultEmoji.textContent = pickEmoji(dest);
                }

                resultCard.style.display = 'block';
                resultCard.scrollIntoView({ behavior: 'smooth', block: 'start' });

                // Style tables
                resultBody.querySelectorAll('table').forEach(t => {
                    t.classList.add('tp-table');
                });
            }

            // ─── Save Trip ────────────────────────────────────────────────────────
            saveTripBtn.addEventListener('click', async () => {
                const dest = document.getElementById('destination').value.trim();
                const duration = document.getElementById('duration').value;
                const travelers = document.getElementById('travelers').value;
                const budget = document.getElementById('budget').value;
                const prefs = document.getElementById('preferences').value.trim();

                if (!currentPlanContent) { showToast('No plan to save yet!', 'warning'); return; }

                saveTripBtn.textContent = '⏳ Saving…';
                saveTripBtn.disabled = true;

                try {
                    const res = await fetch('/api/trip/save', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                        },
                        credentials: 'include',
                        body: JSON.stringify({
                            destination: dest,
                            duration, travelers, budget,
                            preferences: prefs,
                            content: currentPlanContent,
                            title: `${duration}-Day Trip to ${dest}`
                        })
                    });

                    const data = await res.json();
                    if (res.status === 401) {
                        showToast('Please log in to save trips!', 'warning');
                        setTimeout(() => window.location.href = '/login', 1500);
                        return;
                    }
                    if (data.success) {
                        showToast('Trip saved! 🎉 View it in My Trips.', 'success');
                        saveTripBtn.textContent = '✅ Saved!';
                    } else {
                        throw new Error(data.message);
                    }
                } catch (err) {
                    console.error(err);
                    showToast(err.message || 'Failed to save trip.', 'error');
                    saveTripBtn.textContent = '💾 Save';
                } finally {
                    saveTripBtn.disabled = false;
                }
            });

            // ─── Copy ─────────────────────────────────────────────────────────────
            copies.addEventListener('click', async () => {
                try {
                    await navigator.clipboard.writeText(currentPlanContent);
                    copies.textContent = '✅ Copied!';
                    showToast('Itinerary copied to clipboard!', 'success');
                    setTimeout(() => copies.textContent = '📋 Copy', 2000);
                } catch {
                    showToast('Could not copy — select and copy manually.', 'warning');
                }
            });

            // ─── Print ────────────────────────────────────────────────────────────
            printBtn.addEventListener('click', () => {
                const dest = document.getElementById('destination').value || 'Trip';
                const win = window.open('', '_blank');
                win.document.write(`
            <html><head><title>${dest} Itinerary — WanderLust</title>
            <style>
                body { font-family: Georgia, serif; max-width: 800px; margin: 40px auto; color: #222; }
                h1,h2,h3 { color: #4f46e5; }
                table { width: 100%; border-collapse: collapse; margin: 16px 0; }
                th { background: #4f46e5; color: white; padding: 8px 12px; }
                td { border: 1px solid #ddd; padding: 8px 12px; }
                @media print { body { margin: 0; } }
            </style></head>
            <body>${resultBody.innerHTML}</body></html>`);
                win.document.close();
                win.print();
            });

            // ─── Share ────────────────────────────────────────────────────────────
            shareBtn.addEventListener('click', async () => {
                const dest = document.getElementById('destination').value || 'My Trip';
                const duration = document.getElementById('duration').value;
                if (navigator.share) {
                    try {
                        await navigator.share({
                            title: `${duration}-Day Trip to ${dest} | WanderLust`,
                            text: `Check out this AI-generated trip plan for ${dest}!`,
                            url: window.location.href
                        });
                    } catch (_) { }
                } else {
                    await navigator.clipboard.writeText(window.location.href).catch(() => { });
                    showToast('Link copied to clipboard!', 'success');
                }
            });

            // ─── Voice Input ──────────────────────────────────────────────────────
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (SpeechRecognition) {
                const recognition = new SpeechRecognition();
                recognition.lang = 'en-IN';
                recognition.interimResults = true;

                recognition.onresult = (e) => {
                    const transcript = Array.from(e.results).map(r => r[0].transcript).join('');
                    document.getElementById('preferences').value = transcript;
                };
                recognition.onend = () => {
                    voiceIcon.textContent = '🎙️';
                    voiceText.textContent = 'Voice Input';
                    voiceBtn.classList.remove('active');
                };
                recognition.onerror = (e) => {
                    showToast('Voice error: ' + e.error, 'warning');
                };

                voiceBtn.addEventListener('click', () => {
                    if (voiceBtn.classList.contains('active')) {
                        recognition.stop();
                    } else {
                        recognition.start();
                        voiceIcon.textContent = '🔴';
                        voiceText.textContent = 'Listening…';
                        voiceBtn.classList.add('active');
                    }
                });
            } else {
                voiceBtn.disabled = true;
                voiceBtn.title = 'Speech recognition not supported';
            }

            // ─── Helpers ──────────────────────────────────────────────────────────
            function pickEmoji(dest = '') {
                const d = dest.toLowerCase();
                if (d.includes('goa') || d.includes('beach') || d.includes('kerala')) return '🏖️';
                if (d.includes('manali') || d.includes('shimla') || d.includes('leh')) return '🏔️';
                if (d.includes('rishikesh')) return '🛶';
                if (d.includes('rajasthan') || d.includes('jaipur')) return '🏰';
                if (d.includes('mumbai') || d.includes('delhi')) return '🏙️';
                return '✈️';
            }

            function showToast(msg, type = 'info') {
                const colors = {
                    success: '#10b981',
                    error: '#ef4444',
                    warning: '#f59e0b',
                    info: '#6366f1'
                };
                const icons = { success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
                const id = 'toast-' + Date.now();

                const el = document.createElement('div');
                el.id = id;
                el.className = 'tp-toast';
                el.style.cssText = `--toast-color:${colors[type] || colors.info}`;
                el.innerHTML = `<span class="tp-toast-icon">${icons[type] || 'ℹ️'}</span><span class="tp-toast-msg">${msg}</span><button class="tp-toast-close" onclick="document.getElementById('${id}').remove()">×</button>`;

                document.getElementById('toast-container').appendChild(el);

                // Animate in
                requestAnimationFrame(() => el.classList.add('show'));

                // Auto remove
                setTimeout(() => {
                    el.classList.remove('show');
                    setTimeout(() => el.remove(), 400);
                }, 4000);
            }

            // Expose for inline usage
            window._showToast = showToast;
        })();
    </script>

    <style>
        /* ═══════════════════════════════════════════════════
   TRIP PLANNER — PREMIUM DESIGN SYSTEM
   ═══════════════════════════════════════════════════ */

        /* Google Font */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        :root {
            --tp-primary: #6366f1;
            --tp-primary2: #818cf8;
            --tp-dark: #0f0e1a;
            --tp-surface: #1a1830;
            --tp-surface2: #221f3a;
            --tp-border: rgba(99, 102, 241, .25);
            --tp-text: #e2e2f0;
            --tp-muted: #9ca3af;
            --tp-success: #10b981;
            --tp-warning: #f59e0b;
            --tp-radius: 14px;
            --tp-shadow: 0 20px 60px rgba(0, 0, 0, .4);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        /* ─── Hero ─────────────────────────────────────────────────────── */
        .tp-hero {
            position: relative;
            background: linear-gradient(135deg, #0f0e1a 0%, #1a1245 50%, #0f0e1a 100%);
            padding: 5rem 0 4rem;
            overflow: hidden;
        }

        .tp-hero-bg {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 70% 60% at 50% -10%, rgba(99, 102, 241, .35) 0%, transparent 70%);
            pointer-events: none;
        }

        .tp-hero-content {
            position: relative;
            z-index: 1;
